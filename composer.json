{
    "name": "brikshya/laravel-generator",
    "description": "A comprehensive Laravel package for generating migrations, models, controllers, services, enums, views with beautiful modal dialogs, and all related components",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "generator",
        "artisan",
        "crud",
        "scaffold",
        "migration",
        "model",
        "controller",
        "service",
        "enum",
        "views",
        "modal",
        "dialogs",
        "package"
    ],
    "authors": [
        {
            "name": "Brikshya"
        }
    ],
    "homepage": "https://github.com/Samip91/laravel-generator",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Brikshya\\LaravelGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brikshya\\LaravelGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Brikshya\\LaravelGenerator\\LaravelGeneratorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
